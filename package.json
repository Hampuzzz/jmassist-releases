{
  "name": "verkstads-erp",
  "version": "1.8.5",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "lookup": "node scripts/vehicle-lookup-service.mjs",
    "electron:dev": "concurrently --kill-others \"npm run dev\" \"wait-on http://127.0.0.1:3000 && electron .\"",
    "electron:build": "next build && electron-builder --win --x64",
    "electron:pack": "next build && electron-builder --win --x64 --dir"
  },
