# ============================================================
# Supabase - Local (supabase start)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# Supabase - Cloud (production)
# NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<project-anon-key>
# SUPABASE_SERVICE_ROLE_KEY=<project-service-role-key>

# ============================================================
# Database (Drizzle direct connection)
# ============================================================
# Local Supabase (port 54322):
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
# Cloud pooler (production):
# DATABASE_URL=postgresql://postgres:<password>@<project-id>.pooler.supabase.com:6543/postgres

# ============================================================
# External Vehicle Data API
# ============================================================
# Leave empty to use mock data in development
BILVISION_API_KEY=
BILVISION_API_URL=https://api.bilvision.se/v1

# Car.info alternative
CARINFO_API_KEY=
CARINFO_API_URL=https://api.car.info/v1

# ============================================================
# Parts Supplier API
# ============================================================
BILXTRA_API_KEY=
BILXTRA_API_URL=https://api.bilxtra.se/v2
BILXTRA_CUSTOMER_ID=

# ============================================================
# Application Settings
# ============================================================
NEXT_PUBLIC_APP_NAME=Verkstads-ERP
NEXT_PUBLIC_APP_URL=http://localhost:3000

WORKSHOP_NAME="Min Bilverkstad AB"
WORKSHOP_ORG_NR=556000-0000
WORKSHOP_VAT_NR=SE556000000001
WORKSHOP_BANK_ACCOUNT=
WORKSHOP_HOURLY_RATE=850

# ============================================================
# CORS & External Access
# ============================================================
# Comma-separated list of allowed origins for /api/book and /api/availability
ALLOWED_ORIGINS=https://dinverkstad.se,https://www.dinverkstad.se

# Public-facing URL (set to Cloudflare Tunnel URL when deployed)
NEXT_PUBLIC_API_URL=http://localhost:3000

# ============================================================
# Scheduling & iCal
# ============================================================
# Random 32+ char secret for signing iCal download tokens
ICAL_SECRET=change-this-to-a-long-random-string-32chars

# ============================================================
# Fortnox Integration
# ============================================================
# Leave empty for mock mode (logs to console)
FORTNOX_ACCESS_TOKEN=
FORTNOX_BASE_URL=https://api.fortnox.se/3

# ============================================================
# 46elks SMS (empty = mock mode, logs to console)
# ============================================================
ELKS_API_USERNAME=
ELKS_API_PASSWORD=
ELKS_SENDER=JMAssist

# ============================================================
# Customer Approval
# ============================================================
# Uses ICAL_SECRET as fallback if not set
APPROVAL_SECRET=

# ============================================================
# Email (for sending invoices)
# ============================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=faktura@dinverkstad.se

# ============================================================
# Cloudflare Tunnel (set after cloudflared setup)
# ============================================================
CLOUDFLARE_TUNNEL_TOKEN=
